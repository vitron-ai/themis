{
  "name": "themis-vscode",
  "displayName": "Themis",
  "description": "Review Themis test and generate artifacts, rerun suites, and open the HTML verdict report inside VS Code.",
  "version": "1.0.17",
  "license": "MIT",
  "publisher": "vitron-ai",
  "icon": "resources/themis-package-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitron-ai/themis.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "themis",
    "testing",
    "unit-test",
    "ai",
    "agents",
    "html-report"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onView:themis.results",
    "onCommand:themis.runTests",
    "onCommand:themis.rerunFailed",
    "onCommand:themis.updateContracts",
    "onCommand:themis.runMigrationCodemods",
    "onCommand:themis.openHtmlReport",
    "onCommand:themis.refreshResults",
    "onCommand:themis.openArtifactFile"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "themis",
          "title": "Themis",
          "icon": "resources/themis-activity-icon.svg"
        }
      ]
    },
    "views": {
      "themis": [
        {
          "id": "themis.results",
          "name": "Results"
        }
      ]
    },
    "commands": [
      {
        "command": "themis.runTests",
        "title": "Themis: Run Tests",
        "category": "Themis"
      },
      {
        "command": "themis.rerunFailed",
        "title": "Themis: Rerun Failed",
        "category": "Themis"
      },
      {
        "command": "themis.updateContracts",
        "title": "Themis: Update Contracts",
        "category": "Themis"
      },
      {
        "command": "themis.runMigrationCodemods",
        "title": "Themis: Run Migration Codemods",
        "category": "Themis"
      },
      {
        "command": "themis.openHtmlReport",
        "title": "Themis: Open HTML Report",
        "category": "Themis"
      },
      {
        "command": "themis.refreshResults",
        "title": "Themis: Refresh Results",
        "category": "Themis"
      },
      {
        "command": "themis.openArtifactFile",
        "title": "Themis: Open Artifact File",
        "category": "Themis"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "themis.runTests",
          "when": "view == themis.results",
          "group": "navigation@1"
        },
        {
          "command": "themis.rerunFailed",
          "when": "view == themis.results",
          "group": "navigation@2"
        },
        {
          "command": "themis.openHtmlReport",
          "when": "view == themis.results",
          "group": "navigation@3"
        },
        {
          "command": "themis.updateContracts",
          "when": "view == themis.results",
          "group": "navigation@4"
        },
        {
          "command": "themis.refreshResults",
          "when": "view == themis.results",
          "group": "navigation@5"
        }
      ]
    },
    "colors": [
      {
        "id": "themis.color.pass",
        "description": "Primary success color for cleared Themis verdicts and resolved review groups.",
        "defaults": {
          "dark": "#4DB889",
          "light": "#1F7A52",
          "highContrast": "#5EE6A8",
          "highContrastLight": "#146B45"
        }
      },
      {
        "id": "themis.color.fail",
        "description": "Primary failure color for active Themis test failures and broken artifact states.",
        "defaults": {
          "dark": "#E26D5A",
          "light": "#B63E2E",
          "highContrast": "#FF8F7F",
          "highContrastLight": "#9C2313"
        }
      },
      {
        "id": "themis.color.review",
        "description": "Review color for contract drift, migration actions, and intervention-needed generated work.",
        "defaults": {
          "dark": "#E3A23B",
          "light": "#A86B00",
          "highContrast": "#FFD37A",
          "highContrastLight": "#8A5600"
        }
      },
      {
        "id": "themis.color.insight",
        "description": "Insight color for generated mappings, report navigation, and runtime context.",
        "defaults": {
          "dark": "#5CB8D8",
          "light": "#0D6F94",
          "highContrast": "#86E0FF",
          "highContrastLight": "#005B79"
        }
      },
      {
        "id": "themis.color.muted",
        "description": "Muted utility color for empty or inactive Themis states.",
        "defaults": {
          "dark": "#94A3B8",
          "light": "#5F6B7A",
          "highContrast": "#C8D4E5",
          "highContrastLight": "#3F4A58"
        }
      }
    ],
    "configuration": {
      "title": "Themis",
      "properties": {
        "themis.command": {
          "type": "string",
          "default": "npx themis test",
          "description": "Command used by the Themis extension to run the full suite."
        },
        "themis.rerunFailedCommand": {
          "type": "string",
          "default": "npx themis test --rerun-failed",
          "description": "Command used by the Themis extension to rerun failures from the latest artifact."
        },
        "themis.updateContractsCommand": {
          "type": "string",
          "default": "npx themis test --update-contracts",
          "description": "Command used by the Themis extension to accept reviewed contract baselines."
        },
        "themis.migrationCommand": {
          "type": "string",
          "default": "",
          "description": "Optional override used by the Themis extension when running migration codemods. Defaults to `npx themis migrate <source> --convert`."
        }
      }
    }
  }
}
